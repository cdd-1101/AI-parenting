/* pages/chat/history.wxss */

/* 顶部 */
.header-section {
  padding: var(--space-lg);
  padding-bottom: var(--space-md);
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: var(--space-xs);
}

.header-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 加载 */
.loading-container {
  padding: var(--space-lg);
}

.skeleton-card {
  height: 120rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  margin-bottom: var(--space-md);
  animation: skeleton-pulse 1.5s ease-in-out infinite;
}

@keyframes skeleton-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* 历史列表 */
.history-list {
  padding: var(--space-md) var(--space-lg);
}

.history-item {
  margin-bottom: var(--space-sm);
}

.item-header {
  display: flex;
  align-items: center;
}

.item-icon {
  font-size: 40rpx;
  margin-right: var(--space-md);
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.item-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.item-time {
  font-size: 22rpx;
  color: var(--color-text-hint);
}

.item-actions {
  flex-shrink: 0;
}

.delete-btn {
  font-size: 24rpx;
  color: #E53935;
  padding: 8rpx 20rpx;
  border: 1rpx solid #FFCDD2;
  border-radius: var(--radius-sm);
}

.delete-btn:active {
  background: #FFEBEE;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx var(--space-lg);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: var(--space-lg);
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: var(--space-sm);
}

.empty-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}
