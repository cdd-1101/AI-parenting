<!--pages/chat/history.wxml-->
<!-- 对话历史 -->
<view class="page-container">
  <view class="header-section gradient-primary">
    <text class="header-title">对话历史</text>
    <text class="header-desc">与 AI 助手的聊天记录</text>
  </view>

  <!-- 加载状态 -->
  <view class="loading-container" wx:if="{{loading}}">
    <view class="skeleton-card" wx:for="{{[1,2,3,4]}}" wx:key="*this"></view>
  </view>

  <!-- 对话列表 -->
  <view class="history-list" wx:if="{{!loading}}">
    <view class="history-item card" wx:for="{{conversations}}" wx:key="id"
      bindtap="openConversation" data-id="{{item.id}}">
      <view class="item-header">
        <text class="item-icon">💬</text>
        <view class="item-info">
          <text class="item-title">{{item.title || '新对话'}}</text>
          <text class="item-time">{{item.timeText}}</text>
        </view>
        <view class="item-actions">
          <text class="delete-btn" catchtap="deleteConversation" data-id="{{item.id}}">删除</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && conversations.length === 0}}">
    <text class="empty-icon">💬</text>
    <text class="empty-title">暂无对话记录</text>
    <text class="empty-desc">去和 AI 助手聊聊天吧</text>
    <view class="btn-primary" style="margin-top: 40rpx; width: 320rpx;"
      bindtap="goChat">开始对话</view>
  </view>
</view>
