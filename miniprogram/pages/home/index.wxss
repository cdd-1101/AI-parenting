/* pages/home/index.wxss */

.page-container {
  padding-bottom: 32rpx;
}

/* 宝宝日龄卡片 */
.baby-card {
  margin: var(--space-md) var(--space-lg);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  color: #FFFFFF;
}

.baby-card-inner {
  display: flex;
  align-items: center;
}

.baby-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-full);
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  margin-right: var(--space-md);
}

.baby-info {
  flex: 1;
}

.baby-name {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
}

.baby-age {
  font-size: 28rpx;
  display: block;
  margin-top: 4rpx;
}

.baby-age-sub {
  font-size: 22rpx;
  opacity: 0.8;
  display: block;
}

.baby-stats {
  display: flex;
  gap: var(--space-lg);
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
}

.stat-label {
  font-size: 20rpx;
  opacity: 0.8;
}

/* 区块标题 */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: var(--space-md);
  display: flex;
  align-items: center;
}

.tip-icon {
  margin-right: var(--space-xs);
}

/* 宫格菜单 */
.grid-menu {
  display: flex;
  flex-wrap: wrap;
}

.grid-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-md) 0;
}

.grid-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-xs);
}

.grid-emoji {
  font-size: 40rpx;
}

.grid-label {
  font-size: 24rpx;
  color: var(--color-text-primary);
}

/* 发育提醒 */
.tip-list {
  background: var(--color-accent-light);
  border-radius: var(--radius-md);
  padding: var(--space-md);
}

.tip-item {
  display: flex;
  padding: var(--space-xs) 0;
}

.tip-dot {
  color: var(--color-accent);
  margin-right: var(--space-sm);
  font-weight: 700;
}

.tip-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  flex: 1;
}

/* AI 入口卡片 */
.ai-entry-card {
  margin: var(--space-sm) var(--space-lg);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  display: flex;
  align-items: center;
}

.ai-emoji {
  font-size: 56rpx;
  margin-right: var(--space-md);
}

.ai-text {
  flex: 1;
}

.ai-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
  display: block;
}

.ai-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  display: block;
  margin-top: 4rpx;
}

/* 推荐列表 */
.recommend-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.recommend-item {
  display: flex;
  align-items: center;
  padding-bottom: var(--space-md);
  border-bottom: 1rpx solid var(--color-border);
}

.recommend-item:last-child {
  padding-bottom: 0;
  border-bottom: none;
}

.recommend-info {
  flex: 1;
  margin-right: var(--space-md);
}

.recommend-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  display: block;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.recommend-meta {
  font-size: 22rpx;
  color: var(--color-text-hint);
  display: block;
  margin-top: var(--space-xs);
}

.recommend-img {
  width: 180rpx;
  height: 120rpx;
  border-radius: var(--radius-md);
  flex-shrink: 0;
}
