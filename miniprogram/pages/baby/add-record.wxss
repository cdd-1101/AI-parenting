/* pages/baby/add-record.wxss */

/* 类型选择 */
.type-section {
  padding: var(--space-md) var(--space-lg);
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: var(--space-sm);
}

.type-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
}

.type-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: calc(33.33% - 32rpx);
  height: 140rpx;
  background: var(--color-bg-card);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-lg);
  transition: all 0.2s;
}

.type-option.active {
  border-color: var(--color-primary);
  background: #FFF0EE;
}

.type-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.type-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.type-option.active .type-label {
  color: var(--color-primary);
}

/* 日期选择 */
.form-section {
  padding: var(--space-sm) var(--space-lg);
}

.date-picker {
  background: var(--color-bg-card);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: var(--space-md) var(--space-lg);
  font-size: 28rpx;
  color: var(--color-text-hint);
}

.date-picker.has-value {
  color: var(--color-text-primary);
  border-color: var(--color-primary);
}

/* 表单卡片 */
.form-card {
  padding: 0;
}

.form-group {
  padding: var(--space-md) var(--space-lg);
  border-bottom: 1rpx solid var(--color-border);
}

.form-group:last-child {
  border-bottom: none;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: var(--space-sm);
}

.form-input {
  width: 100%;
  height: 72rpx;
  background: var(--color-bg-section);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 0 var(--space-md);
  font-size: 28rpx;
  color: var(--color-text-primary);
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  background: var(--color-bg-section);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--space-md);
  font-size: 28rpx;
  color: var(--color-text-primary);
  box-sizing: border-box;
  line-height: 1.6;
}

/* 单选组 */
.radio-group {
  display: flex;
  gap: var(--space-sm);
}

.radio-item {
  flex: 1;
  padding: 16rpx 0;
  text-align: center;
  background: var(--color-bg-section);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.radio-item.active {
  border-color: var(--color-primary);
  background: #FFF0EE;
  color: var(--color-primary);
  font-weight: 500;
}

/* 提交按钮 */
.submit-section {
  padding: var(--space-xl) var(--space-lg);
}
