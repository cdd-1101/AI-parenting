/* pages/baby/growth-chart.wxss */

.page-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: var(--color-bg-main);
}

/* 顶部 */
.header-section {
  padding: var(--space-lg);
  padding-bottom: var(--space-md);
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: var(--space-xs);
}

.header-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 类型切换 */
.chart-tabs-wrapper {
  padding: var(--space-md) var(--space-lg);
  background: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border);
}

.chart-tabs {
  display: flex;
  gap: var(--space-md);
}

.chart-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: var(--space-md) 0;
  border-radius: var(--radius-lg);
  background: var(--color-bg-section);
  font-size: 28rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
  transition: all 0.2s ease;
}

.chart-tab.active {
  background: var(--color-primary);
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
}

.tab-icon {
  font-size: 32rpx;
}

.tab-text {
  font-size: 28rpx;
}

/* 图表区域 */
.chart-section {
  margin: var(--space-md) var(--space-lg);
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--space-md);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.chart-wrapper {
  width: 100%;
  height: 480rpx;
  position: relative;
}

.growth-canvas {
  width: 100%;
  height: 100%;
}

.chart-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.chart-empty-icon {
  font-size: 80rpx;
  margin-bottom: var(--space-md);
}

.chart-empty-text {
  font-size: 26rpx;
  color: var(--color-text-hint);
  text-align: center;
}

/* 数据统计 */
.stats-section {
  margin: var(--space-md) var(--space-lg);
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.stat-row {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: var(--color-text-hint);
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.stat-unit {
  font-size: 22rpx;
  font-weight: 400;
  color: var(--color-text-secondary);
}

/* 数据列表 */
.data-section {
  margin: var(--space-md) var(--space-lg);
  margin-bottom: var(--space-xl);
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: var(--space-md);
}

.data-list {
  display: flex;
  flex-direction: column;
}

.data-row {
  display: flex;
  align-items: center;
  padding: var(--space-md) 0;
  border-bottom: 1rpx solid var(--color-border);
}

.data-row:last-child {
  border-bottom: none;
}

.data-date {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  width: 120rpx;
}

.data-age {
  font-size: 24rpx;
  color: var(--color-text-hint);
  flex: 1;
}

.data-value {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
  text-align: right;
}
