/* pages/knowledge/month-detail.wxss */

/* 顶部 */
.header-section {
  padding: var(--space-lg);
  padding-bottom: var(--space-xl);
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: var(--space-xs);
}

.header-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 标签导航 */
.tab-scroll {
  background: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border);
  white-space: nowrap;
}

.tab-bar {
  display: inline-flex;
  padding: var(--space-sm) var(--space-md);
  gap: var(--space-sm);
}

.tab-item {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 28rpx;
  border-radius: var(--radius-full);
  background: var(--color-bg-section);
  font-size: 24rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
  white-space: nowrap;
  flex-shrink: 0;
}

.tab-item.active {
  background: var(--color-primary);
  color: #FFFFFF;
}

/* 加载 */
.loading-container {
  padding: var(--space-lg);
}

.skeleton-block {
  height: 240rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  margin-bottom: var(--space-md);
  animation: skeleton-pulse 1.5s ease-in-out infinite;
}

@keyframes skeleton-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* 内容滚动区 */
.content-scroll {
  height: calc(100vh - 340rpx);
  padding: 0 var(--space-lg);
}

/* 板块区块 */
.section-block {
  padding-top: var(--space-md);
}

.section-header-bar {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-sm);
}

.section-icon {
  font-size: 32rpx;
  margin-right: var(--space-sm);
}

.section-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
}

/* 板块卡片 */
.section-card {
  margin-bottom: 0;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: var(--space-sm);
}

.section-summary {
  display: block;
  font-size: 26rpx;
  color: var(--color-primary);
  margin-bottom: var(--space-md);
  padding-bottom: var(--space-md);
  border-bottom: 1rpx solid var(--color-border);
  line-height: 1.6;
}

.section-content {
  /* 内容区域 */
}

.content-text {
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 2;
  white-space: pre-wrap;
  word-break: break-all;
}
