/* pages/mine/favorites.wxss */

/* 顶部 */
.header-section {
  padding: var(--space-lg);
  padding-bottom: var(--space-md);
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: var(--space-xs);
}

.header-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* Tab */
.tab-bar {
  display: flex;
  padding: var(--space-sm) var(--space-lg);
  gap: var(--space-sm);
  background: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border);
}

.tab-item {
  padding: 10rpx 28rpx;
  border-radius: var(--radius-full);
  background: var(--color-bg-section);
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.tab-item.active {
  background: var(--color-primary);
  color: #FFFFFF;
}

/* 加载 */
.loading-container {
  padding: var(--space-lg);
}

.skeleton-card {
  height: 140rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  margin-bottom: var(--space-md);
  animation: skeleton-pulse 1.5s ease-in-out infinite;
}

@keyframes skeleton-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* 收藏列表 */
.fav-list {
  padding: var(--space-md) var(--space-lg);
}

.fav-item {
  margin-bottom: var(--space-sm);
}

.fav-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-sm);
}

.fav-type {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
  font-weight: 500;
}

.fav-type.knowledge {
  background: #E8F5E9;
  color: #2E7D32;
}

.fav-type.conversation {
  background: #E3F2FD;
  color: #1565C0;
}

.fav-type.article {
  background: #FFF8E1;
  color: #F57F17;
}

.fav-time {
  font-size: 22rpx;
  color: var(--color-text-hint);
}

.fav-title {
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 500;
  margin-bottom: var(--space-sm);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.fav-actions {
  display: flex;
  justify-content: flex-end;
}

.unfav-btn {
  font-size: 22rpx;
  color: var(--color-text-hint);
  padding: 4rpx 16rpx;
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-sm);
}

.unfav-btn:active {
  color: #E53935;
  border-color: #FFCDD2;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx var(--space-lg);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: var(--space-lg);
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: var(--space-sm);
}

.empty-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  text-align: center;
}
