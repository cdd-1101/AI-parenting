// Prisma Schema - 安心育儿小程序数据库模型
// 对齐 PRD 5.3 节数据库设计

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// 用户表
model User {
  id        Int      @id @default(autoincrement())
  openid    String   @unique @db.VarChar(64)
  unionId   String?  @map("union_id") @db.VarChar(64)
  nickname  String   @default("") @db.VarChar(64)
  avatarUrl String   @default("") @map("avatar_url") @db.VarChar(512)
  phone     String?  @db.VarChar(20)
  role      Role     @default(mother)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  babies        Baby[]
  conversations Conversation[]
  favorites     Favorite[]

  @@index([openid])
  @@map("users")
}

enum Role {
  mother
  father
  grandparent
  other
}

/// 宝宝档案表
model Baby {
  id          Int         @id @default(autoincrement())
  userId      Int         @map("user_id")
  nickname    String      @db.VarChar(64)
  gender      Gender
  birthday    DateTime    @db.Date
  avatarUrl   String      @default("") @map("avatar_url") @db.VarChar(512)
  feedingType FeedingType @default(breast) @map("feeding_type")
  allergies   Json?
  bloodType   String?     @map("blood_type") @db.VarChar(8)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  growthRecords GrowthRecord[]
  conversations Conversation[]

  @@index([userId])
  @@map("babies")
}

enum Gender {
  male
  female
}

enum FeedingType {
  breast
  formula
  mixed
}

/// 成长记录表
model GrowthRecord {
  id         Int          @id @default(autoincrement())
  babyId     Int          @map("baby_id")
  userId     Int          @map("user_id")
  type       RecordType
  recordDate DateTime     @map("record_date") @db.Date
  ageMonth   Int          @default(0) @map("age_month") @db.TinyInt
  ageDay     Int          @default(0) @map("age_day") @db.SmallInt
  data       Json
  note       String?      @db.Text
  images     Json?
  tags       Json?
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  baby Baby @relation(fields: [babyId], references: [id], onDelete: Cascade)

  @@index([babyId, recordDate])
  @@index([babyId, type])
  @@map("growth_records")
}

enum RecordType {
  growth
  feeding
  sleep
  milestone
  photo
  health
  note
}

/// AI 对话会话表
model Conversation {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  babyId    Int      @map("baby_id")
  title     String   @default("") @db.VarChar(128)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  baby     Baby                 @relation(fields: [babyId], references: [id], onDelete: Cascade)
  messages ConversationMessage[]

  @@index([userId, babyId])
  @@map("conversations")
}

/// AI 对话消息表
model ConversationMessage {
  id             Int       @id @default(autoincrement())
  conversationId Int       @map("conversation_id")
  role           MessageRole
  content        String    @db.Text
  tokensUsed     Int       @default(0) @map("tokens_used")
  createdAt      DateTime  @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("conversation_messages")
}

enum MessageRole {
  user
  assistant
  system
}

/// 月龄知识库表
model KnowledgeBase {
  id          Int             @id @default(autoincrement())
  month       Int             @db.TinyInt
  section     KnowledgeSection
  title       String          @db.VarChar(256)
  content     String          @db.Text
  summary     String          @default("") @db.VarChar(512)
  embeddingId String?         @map("embedding_id") @db.VarChar(64)
  source      String          @default("") @db.VarChar(128)
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@unique([month, section])
  @@map("knowledge_base")
}

enum KnowledgeSection {
  physiology
  abilities
  feeding
  sleep
  common_issues
  early_education
}

/// 用户收藏表
model Favorite {
  id         Int          @id @default(autoincrement())
  userId     Int          @map("user_id")
  targetType FavoriteType @map("target_type")
  targetId   Int          @map("target_id")
  createdAt  DateTime     @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId])
  @@map("favorites")
}

enum FavoriteType {
  knowledge
  conversation
  article
}
